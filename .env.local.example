# ─────────────────────────────────────────────────────────────
# GameFolio — variables d'environnement
# Copie ce fichier en `.env.local` et remplis-le.
# ─────────────────────────────────────────────────────────────

# ── Supabase (obligatoire en prod, optionnel en dev) ─────────
# Si NEXT_PUBLIC_SUPABASE_URL est vide, l'app passe en "mode démo"
# (localStorage). Pour la prod, ces 3 variables sont obligatoires.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic (coach IA Prism) ───────────────────────────────
# Clé API pour Claude Opus 4.7. Sans cette clé, /api/coach/chat
# retourne 503 et le widget Prism affiche un message d'erreur.
# Obtenue sur https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── TCGdex (catalogue cartes) ────────────────────────────────
# Public, no auth required. Override only if hitting rate limits.
NEXT_PUBLIC_TCGDEX_BASE_URL=https://api.tcgdex.net/v2

# ── Prix marché (Phase 2 — pas câblé) ────────────────────────
# Tokens des fournisseurs de cotation. Utilisés par le cron quotidien
# `supabase/functions/sync-card-grade-prices`.
PRICECHARTING_API_TOKEN=
TCGPLAYER_PUBLIC_KEY=
TCGPLAYER_PRIVATE_KEY=

# ── Stripe (VIP tier) ────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs des plans (créés dans le dashboard Stripe)
STRIPE_PRICE_ID_PLUS=
STRIPE_PRICE_ID_VIP=

# ── Resend (emails transactionnels) ──────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=GameFolio <hello@gamefolio.app>

# ── PostHog EU (analytics anonymisées) ───────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ── Sentry (crash reporting) ─────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=gamefolio

# ── Géo-blocage (Phase 2 — middleware Edge) ──────────────────
# Pays interdits pour les loot box. Liste séparée par virgules.
BLOCKED_COUNTRIES=BE,NL

# ── Site URL (pour OG + sitemaps + Supabase Auth redirect) ──
NEXT_PUBLIC_SITE_URL=https://gamefolio.app
